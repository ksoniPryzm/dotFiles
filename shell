# History control
shopt -s histappend
HISTCONTROL=ignoreboth
HISTSIZE=32768
HISTFILESIZE="${HISTSIZE}"

# Autocompletion (Linux only — macOS handles this via .bash_profile/Homebrew)
if [[ -z "${BASH_COMPLETION_VERSINFO+x}" && -f /usr/share/bash-completion/bash_completion ]]; then
  source /usr/share/bash-completion/bash_completion
fi

# Set complete path
export PATH="$HOME/.local/bin:$PATH"
set +h
